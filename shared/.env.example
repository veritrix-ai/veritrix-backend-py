# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=agentops
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops

# Internal
INGEST_PORT=8001
API_PORT=8000
ENVIRONMENT=development
INGEST_RATE_LIMIT_PER_MINUTE=1000

# Comma-separated browser origins allowed to call the App API (CORS)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://veritrix-ui.vercel.app

# Clerk (App API auth) — copy publishable key from frontend/.env for local dev
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional override; auto-derived from CLERK_PUBLISHABLE_KEY when unset
CLERK_JWKS_URL=
